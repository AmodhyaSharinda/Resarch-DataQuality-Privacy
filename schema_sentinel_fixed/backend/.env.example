APP_NAME="Schema Drift Backend"
ENV="dev"

# Server
HOST="0.0.0.0"
PORT=8000

# SQLite DB (stored in backend/)
DATABASE_URL="sqlite:///./app.db"

# Storage directory (uploaded dataset configs + optional model artifacts)
STORAGE_DIR="storage"

# Rename model artifacts (optional).
# If not set or not found, backend uses a heuristic rename scorer.
RENAME_MODEL_PATH="storage/models/rename_model_generic_8feat.pkl"
RENAME_FEATURES_PATH="storage/models/rename_model_generic_8feat_features.pkl"
RENAME_THRESHOLD_PATH="storage/models/rename_model_generic_8feat_threshold.json"

# SentenceTransformer model name
EMB_MODEL_NAME="all-MiniLM-L6-v2"

# CORS (frontend)
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Kafka (Live Stream)
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
KAFKA_TOPICS="ingest"
WINDOW_SECONDS=30
MAX_BUFFER_ROWS=5000
MIN_ROWS_FOR_DRIFT=50
